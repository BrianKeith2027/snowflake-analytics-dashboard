# ============================================================
# Snowflake Analytics Dashboard - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your Snowflake credentials.
# NEVER commit .env with real credentials to version control.

# Snowflake Connection
SNOWFLAKE_ACCOUNT=your_account.region
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_WAREHOUSE=ANALYTICS_WH
SNOWFLAKE_DATABASE=RETAIL_ANALYTICS
SNOWFLAKE_SCHEMA=GOLD
SNOWFLAKE_ROLE=SYSADMIN
